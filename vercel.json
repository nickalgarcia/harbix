{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/__/auth/(.*)", "destination": "https://harbix.firebaseapp.com/__/auth/$1" },
    { "source": "/__/firebase/(.*)", "destination": "https://harbix.firebaseapp.com/__/firebase/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}