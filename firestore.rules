rules_version = '2';

// Harbix — permission-matrix security rules
//
// The `agents` collection drives everything. Each document ID is the
// agent's email (e.g. agents/ravon@godchasers.church) with fields:
//   name, email, avatar
//   role:   "admin"  (optional — admins only)
//   access: map of department -> "edit" | "view"  (everyone else)
//
// Examples:
//   Anthony:  access: { av: "edit" }
//   Ravon:    access: { av: "view", tech: "view", facilities: "edit" }
//   Admins:   role: "admin"  (no access map needed)
//
// - admin:           read/update/delete everything
// - "edit" on dept:  read + update tickets in that department
// - "view" on dept:  read tickets in that department, change nothing
// - public:          can create tickets (form) and use QR checkout (inventory)

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isListed() {
      return signedIn()
        && exists(/databases/$(database)/documents/agents/$(request.auth.token.email));
    }

    function me() {
      return get(/databases/$(database)/documents/agents/$(request.auth.token.email)).data;
    }

    function isAdmin() {
      return isListed() && me().get("role", "") == "admin";
    }

    function canSeeDept(dept) {
      return isListed() && dept in me().get("access", {});
    }

    function canEditDept(dept) {
      return isListed() && me().get("access", {}).get(dept, "") == "edit";
    }

    // ── Tickets ─────────────────────────────────────────────
    match /tickets/{ticketId} {
      // ── Public create (anonymous) ────────────────────────
      // Allows the public ticket form to submit while blocking direct-SDK
      // attackers from injecting forged fields (fake status, comments, etc.)
      // or writing multi-MB documents.
      //
      // Constraints:
      //   • Required string fields must be present and within size bounds.
      //   • Server-controlled fields (status, claimedBy, comments, activity)
      //     are locked to their safe initial values.
      //   • Privileged fields (role, assignedTo) must not be present.
      //   • department / priority / ai / photoURL / timestamps are intentionally
      //     unconstrained here — they are either validated outputs of the triage
      //     endpoint or controlled Storage URLs.
      allow create: if
        // ── Required string fields, size-bounded ──────────────────────────
        request.resource.data.name     is string
          && request.resource.data.name.size()     <= 200
        && request.resource.data.issue    is string
          && request.resource.data.issue.size()    <= 3000
        && request.resource.data.location is string
          && request.resource.data.location.size() <= 300
        // contact is optional; if present it must be a bounded string
        && (!('contact' in request.resource.data)
            || (request.resource.data.contact is string
                && request.resource.data.contact.size() <= 300))
        // ── Server-controlled fields locked to safe initial values ────────
        && request.resource.data.status    == "waiting"
        && request.resource.data.claimedBy == null
        && request.resource.data.comments  is list
          && request.resource.data.comments.size() == 0
        // activity must be absent — it is appended via updateDoc only
        && !('activity' in request.resource.data)
        // ── No privileged fields ─────────────────────────────────────────
        && !('role'       in request.resource.data)
        && !('assignedTo' in request.resource.data);

      // ── Agent create (authenticated listed member) ───────────
      // Agents can create tickets from the dashboard with a non-default
      // initial status (e.g. "on-it" when claiming immediately) and with
      // claimedBy pre-set. Same comment/activity/role invariants apply.
      allow create: if isListed()
        && request.resource.data.name     is string
          && request.resource.data.name.size()     <= 200
        && request.resource.data.issue    is string
          && request.resource.data.issue.size()    <= 3000
        && request.resource.data.location is string
          && request.resource.data.location.size() <= 300
        && (!('contact' in request.resource.data)
            || (request.resource.data.contact is string
                && request.resource.data.contact.size() <= 300))
        && request.resource.data.status in ["waiting", "on-it", "done", "closed"]
        && request.resource.data.comments is list
          && request.resource.data.comments.size() == 0
        && !('activity' in request.resource.data)
        && !('role' in request.resource.data);

      // Admins see all; members see departments in their access map
      allow read: if isAdmin() || canSeeDept(resource.data.department);

      // Admins update anything; members update only "edit" departments
      // (including re-routing a misclassified ticket OUT of their lane)
      allow update: if isAdmin() || canEditDept(resource.data.department);

      // Delete is admin-only (spam / test cleanup)
      allow delete: if isAdmin();
    }

    // ── Agents directory ────────────────────────────────────
    match /agents/{agentEmail} {
      // Any listed team member can read the directory (assignment dropdown)
      allow read: if isListed();

      // Only admins can add/change permissions
      allow write: if isAdmin();
    }

    // ── Inventory ───────────────────────────────────────────
    match /inventory/{assetId} {
      allow read: if true;

      // Listed team members can edit any asset field (name, serial, notes, etc.)
      // Anonymous volunteers (QR checkout/return) can only touch the four
      // checkout-related fields — everything else requires a team login.
      allow update: if isAdmin()
        || isListed()
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status', 'checkedOutTo', 'lastReturnedAt', 'lastReturnedBy']);

      // Adding assets requires a listed team member; deleting is admin-only
      allow create: if isListed();
      allow delete: if isAdmin();
    }

    // Checkout history sub-collection — written by the QR flow (no auth needed),
    // readable by any team member, deletable by admins only.
    match /inventory/{assetId}/history/{historyId} {
      allow create: if true;
      allow read:   if isListed();
      allow delete: if isAdmin();
    }
  }
}
