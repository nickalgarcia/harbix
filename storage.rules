rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Ticket photo attachments ─────────────────────────────────────────────
    // Write: intentionally unauthenticated — the public ticket form has no login.
    //   Constrained to images ≤ 10 MB so a public visitor cannot upload
    //   arbitrary file types or arbitrarily large payloads.
    // Read: any authenticated user for now.
    //   TODO: tighten to a custom-claim agent check once App Check is enabled
    //   (paired with the M-03 / App Check follow-up pass).
    match /tickets/{ticketId}/{filename} {
      allow write: if request.resource.size  < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow read:  if request.auth != null;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
